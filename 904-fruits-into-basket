class Solution(object):
    def totalFruit(self, fruits):
        res,total,l=0,0,0
        dict={}
        for r in range(len(fruits)):
            dict[fruits[r]]=dict.get(fruits[r],0)+1
            total+=1
            while len(dict)>2:
                dict[fruits[l]]-=1
                total-=1
                if dict[fruits[l]]==0:
                    dict.pop(fruits[l])
                l+=1
            res=max(res,total)
        return res
