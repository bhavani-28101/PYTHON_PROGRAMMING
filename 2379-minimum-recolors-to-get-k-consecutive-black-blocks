class Solution(object):
    def minimumRecolors(self, blocks, k):
        l,r,res,white=0,0,float('inf'),0
        for r in range(len(blocks)):
            if blocks[r]=='W':
                    white+=1
            if r-l+1>=k+1:
                if blocks[l]=='W':
                    white-=1
                l+=1
            if r-l+1==k:
                res=min(res,white)
        return res
