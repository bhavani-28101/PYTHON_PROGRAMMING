class Solution(object):
    def characterReplacement(self, s, k):
        l,res,count=0,0,0
        dict={}
        for r in range(len(s)):
            dict[s[r]]=dict.get(s[r],0)+1
            count=max(count,dict[s[r]])
            while(r-l+1-count>k):
                dict[s[l]]-=1
                l+=1
            res=max(res,r-l+1)
        return res
              
