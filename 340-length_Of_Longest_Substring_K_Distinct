def lengthOfLongestSubstringKDistinct(s, k):

    l = 0
    res = 0
    d = {}
    if k==0:
      return 0
    for r in range(len(s)):

        d[s[r]] = d.get(s[r], 0) + 1

        while len(d) > k:
            d[s[l]] -= 1

            if d[s[l]] == 0:
                d.pop(s[l])

            l += 1

        res = max(res, r - l + 1)

    return res
