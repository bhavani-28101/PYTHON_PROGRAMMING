class Solution(object):
    def uniformArray(self, nums1):
        even=0
        odd=0
        for i in nums1:
            if i%2==0:
                even+=1
            else:
                odd+=1
        if even==len(nums1) or odd ==len(nums1):
            return True
        minval=min(nums1)
        if minval%2==1:
            return True
        return False
