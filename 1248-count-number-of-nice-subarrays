class Solution(object):
    def atmost(self, nums, k):
        odd,l=0,0
        res=0
        for r in range(len(nums)):
            if ((nums[r]%2)!=0):
                odd+=1
            while(odd>k):
                if ((nums[l]%2)!=0):
                  odd-=1
                l+=1 
            res+=r-l+1
        return res
    def numberOfSubarrays(self,nums,k):
        return self.atmost(nums, k)-self.atmost(nums, k-1)
