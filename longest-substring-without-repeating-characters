class Solution(object):
    def lengthOfLongestSubstring(self, s):
        l,r,res=0,0,0
        window=set()
        for r in range(len(s)):
            while s[r] in window:
                window.remove(s[l])
                l+=1
            window.add(s[r])
            res=max(res,len(s[l:r+1]))
        return res
